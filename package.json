    "lint:fix": "npm run lint:eslint -- --fix && npm run lint:prettier -- --write",
    "test": "mocha",
    "test:coverage": "nyc --reporter=lcov --reporter=text-summary npm run test",
    "test:watch": "mocha --watch"
  },
  "dependencies": {
